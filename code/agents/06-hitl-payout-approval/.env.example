# Either set a Gemini API key...
GOOGLE_API_KEY=

# ...or use Vertex AI (needs gcloud ADC + project/location).
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Optional model override.
# HITL_PAYOUT_MODEL=gemini-3-flash-preview

# Optional port override (default 8006).
# PORT=8006
