# Copy to .env. One of the two auth blocks is required.

GOOGLE_API_KEY=

# Vertex alternative:
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Live model. As of April 2026 the GA native-audio Live model is
# gemini-live-2.5-flash-native-audio. The workshop's target was a
# "Gemini 3.1 Flash Live" that is not yet released; swap this value the
# moment Google ships it.
VOICE_MODEL=gemini-live-2.5-flash-native-audio

# Voice selection. Aoede is calm and measured; Puck is brighter;
# Charon is deeper. Pick by ear.
VOICE_NAME=Aoede
