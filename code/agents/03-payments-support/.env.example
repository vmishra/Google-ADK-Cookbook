# Copy to .env. One of the two auth blocks is required.

GOOGLE_API_KEY=

# Vertex alternative:
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Live model. gemini-3.1-flash-live-preview is the current 3.1-family
# native-audio model (preview). If your project does not have access to
# the preview, fall back to gemini-live-2.5-flash-native-audio (Vertex
# GA) — overriding this value is a one-line change.
VOICE_MODEL=gemini-3.1-flash-live-preview

# Voice selection. The agent presents as a female support specialist
# named Kavya. Kore is the default — a measured, lower-register female
# voice. Other female voices: Aoede (brighter), Leda (soft). Male
# voices available: Puck, Charon, Fenrir, Zephyr (neutral). Pick by ear.
VOICE_NAME=Kore

# Context-window compression for long calls. Defaults match Google's
# recommended values for the Live API — triggers at ~100k tokens,
# compresses to ~50k. Raise LIVE_COMPRESSION_TRIGGER_TOKENS if your
# calls are short and you want the full context retained.
LIVE_COMPRESSION_TRIGGER_TOKENS=104857
LIVE_COMPRESSION_TARGET_TOKENS=52428
