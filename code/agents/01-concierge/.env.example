# Copy to .env. One of the two auth blocks is required.

# --- Option 1. AI Studio key (simplest).
GOOGLE_API_KEY=

# --- Option 2. Vertex AI on Google Cloud. Requires `gcloud auth
# application-default login` on the machine, and these three variables.
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# --- Model override. If gemini-3.1-flash is not yet enabled on your
# project, fall back to gemini-2.5-flash.
CONCIERGE_MODEL=gemini-3.1-flash
