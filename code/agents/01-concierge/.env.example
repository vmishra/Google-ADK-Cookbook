# Copy to .env. One of the two auth blocks is required.

# --- Option 1. AI Studio key (simplest).
GOOGLE_API_KEY=

# --- Option 2. Vertex AI on Google Cloud. Requires `gcloud auth
# application-default login` on the machine, and these three variables.
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# --- Model override. Every agent uses the Gemini 3.1 family; switch
# the ID here if you want the Pro tier for sharper answers
# (gemini-3.1-pro-preview) or the cheaper Lite tier (gemini-3.1-flash-lite-preview).
CONCIERGE_MODEL=gemini-3-flash-preview
