# Copy to .env. One of the two auth blocks is required.

GOOGLE_API_KEY=

# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Primary model — used by the planner and the composer (richer writing).
PLANNER_MODEL=gemini-3.1-flash

# Worker model — used by the three parallel researchers. Gemini
# 3.1 Flash-Lite is deliberately chosen here: the research phase is
# tool-call-heavy and benefits from the lower latency and cost.
PLANNER_WORKER_MODEL=gemini-3.1-flash-lite
