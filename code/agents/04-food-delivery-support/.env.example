# Copy to .env. One of the two auth blocks is required.

GOOGLE_API_KEY=

# Vertex alternative:
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Computer-use model. Overridable in case the preview tag rotates.
CU_MODEL=gemini-2.5-computer-use-preview-10-2025

# Browser confinement. The agent's before_tool callback refuses any
# navigation outside this origin.
CU_ALLOWED_ORIGIN=http://127.0.0.1:8004
CU_START_URL=http://127.0.0.1:8004/dashboard/

# Set HEADLESS=true to hide the Chromium window during demos.
HEADLESS=false
