# Either set a Gemini API key...
GOOGLE_API_KEY=

# ...or use Vertex AI.
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Model overrides.
# LOAN_OFFICER_MODEL=gemini-3-flash-preview
# BUREAU_MODEL=gemini-3.1-flash-lite-preview

# Ports (defaults).
# PORT=8007
# BUREAU_PORT=8017

# Where the officer reaches the bureau. Override to point at another
# host / port in production.
# BUREAU_URL=http://127.0.0.1:8017
